{
  "manifest_version": 3,
  "name": "I'm A Movie Wimp",
  "version": "0.1.0",
  "description": "A spoiler-free pop-up for movie wimps (like me)",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "tabs"]
}
